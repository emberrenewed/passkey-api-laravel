APP_NAME="Passkey Auth API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=passkey_auth
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ============================================================
# PASSKEY / WEBAUTHN CONFIGURATION
# ============================================================
# The Relying Party ID - typically your domain name without protocol or port.
# For local development, use "localhost".
# For production, use your actual domain: "example.com"
PASSKEY_RP_ID=localhost

# The human-readable name shown in browser Passkey prompts.
PASSKEY_RP_NAME="Passkey Auth API"

# Comma-separated list of allowed origins for WebAuthn verification.
# Must include protocol. For local dev: http://localhost:3000,http://localhost:5173
# For production: https://example.com
PASSKEY_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# How long a challenge remains valid, in seconds. Default: 300 (5 minutes).
PASSKEY_CHALLENGE_TTL=300

# Timeout in milliseconds for the WebAuthn ceremony in the browser. Default: 60000 (60 seconds).
PASSKEY_TIMEOUT_MS=60000

# User verification requirement: "required", "preferred", or "discouraged".
# "preferred" lets the OS decide; "required" forces biometric/PIN on every use.
PASSKEY_USER_VERIFICATION=preferred

# Attestation conveyance preference: "none", "indirect", or "direct".
# "none" is recommended for most apps (simplest, most privacy-friendly).
PASSKEY_ATTESTATION=none

# Resident key requirement: "required", "preferred", or "discouraged".
# "required" enables discoverable credentials (username-less login).
PASSKEY_RESIDENT_KEY=required

# Authenticator attachment: "platform", "cross-platform", or null (no preference).
# "platform" restricts to built-in authenticators (Touch ID, Windows Hello, etc.).
# null allows both platform and roaming (USB keys, etc.).
PASSKEY_AUTHENTICATOR_ATTACHMENT=

# Enable or disable the passkey feature entirely from the backend.
PASSKEY_ENABLED=true

# Enable strict origin validation. Set to false only in development if needed.
PASSKEY_STRICT_ORIGIN=true

# Enable security audit logging for WebAuthn events.
PASSKEY_AUDIT_LOG=true

# ============================================================
# SANCTUM
# ============================================================
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173,127.0.0.1,127.0.0.1:8000
